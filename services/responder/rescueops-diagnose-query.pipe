{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "name": "Chat",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": {
        "position": { "x": 20, "y": 200 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "name": "Diagnosis Prompt",
      "config": {
        "instructions": [
          "You are an on-call engineer diagnosing a production incident from the context provided in the question: incident summary, root-cause source, failing tests, blast-radius callers, and retrieved runbooks.",
          "Ground every claim in the provided source — quote the exact broken expression. Do not invent files or imports not in the context.",
          "Respond with ONLY a JSON object. No markdown fences. No prose before or after.",
          "Required keys: severity (low|medium|high), root_cause_explanation, proposed_fix_approach, cited_runbook (exact title or null), candidate_fix ({path, content}).",
          "candidate_fix.path is repo-relative (e.g. src/tax.ts). candidate_fix.content is the FULL corrected file — every line preserved except the broken expression.",
          "If N candidates requested, add candidate_fixes array; first element must equal candidate_fix.",
          "Example shape: {\"severity\":\"high\",\"root_cause_explanation\":\"computeTax uses + not *\",\"proposed_fix_approach\":\"Use multiplication\",\"cited_runbook\":\"Wrong operator in arithmetic computation\",\"candidate_fix\":{\"path\":\"src/tax.ts\",\"content\":\"...full file...\"}}"
        ],
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "chat_1" }],
      "ui": {
        "position": { "x": 240, "y": 200 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "llm_openai_api_1",
      "provider": "llm_openai_api",
      "name": "Butterbase AI Gateway",
      "config": {
        "profile": "custom",
        "custom": {
          "model": "${ROCKETRIDE_BUTTERBASE_MODEL}",
          "base_url": "${ROCKETRIDE_BUTTERBASE_GATEWAY_URL}",
          "modelTotalTokens": 32768,
          "apikey": "${ROCKETRIDE_BUTTERBASE_API_KEY}"
        },
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "prompt_1" }],
      "ui": {
        "position": { "x": 460, "y": 200 },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "name": "Return Answers",
      "config": { "laneName": "answers" },
      "input": [{ "lane": "answers", "from": "llm_openai_api_1" }],
      "ui": {
        "position": { "x": 680, "y": 200 },
        "nodeType": "default",
        "formDataValid": true
      }
    }
  ],
  "project_id": "2d9f458a-3a0f-4d3c-afee-52315173a68d",
  "viewport": { "x": 0, "y": 0, "zoom": 1 },
  "version": 1,
  "source": "chat_1"
}
