    {
      "id": "db_neo4j_1",
      "provider": "db_neo4j",
      "name": "Neo4j Code Graph",
      "config": {
        "profile": "default",
        "default": {
          "db_description": "RescueOps++ code dependency graph for a TypeScript codebase. Nodes: (:Function {name, file, status, changed}), (:Test {name, file, status}), (:Runbook {title, text}). Relationships: (:Function)-[:CALLS]->(:Function), (:Test)-[:TESTS]->(:Function), (:Runbook)-[:APPLIES_TO]->(:Function). Used to find the root-cause function of a failing incident, its blast radius via CALLS, the tests that cover it, and the runbooks that apply.",
          "uri": "${ROCKETRIDE_NEO4J_URI}",
          "auth_method": "userpass",
          "user": "${ROCKETRIDE_NEO4J_USER}",
          "password": "${ROCKETRIDE_NEO4J_PASSWORD}",
          "database": "${ROCKETRIDE_NEO4J_DATABASE}",
          "max_attempts": 5,
          "allow_execute": false
        }
      },
      "ui": {
        "position": {
          "x": 500,
          "y": 420
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_rocketride_1"
        }
