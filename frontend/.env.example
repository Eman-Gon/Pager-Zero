# Copy to .env.local (or let ./scripts/dev-native.sh generate it from root .env)

# Backend endpoints. Defaults are /sensor + /responder, which work through
# Next rewrites in local dev and Docker. For static/hosted export deploys these
# must be absolute public URLs.
NEXT_PUBLIC_SENSOR_URL=http://127.0.0.1:3003
NEXT_PUBLIC_RESPONDER_URL=http://127.0.0.1:3004

# Neo4j browser-bolt for the graph panel. WARNING: Next bakes these into the JS
# bundle — anyone loading a deployed build gets the DB password. Leave BLANK for
# hosted builds (the graph falls back to the /incident subgraph, server-side).
NEXT_PUBLIC_NEO4J_URL=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEXT_PUBLIC_NEO4J_USER=neo4j
NEXT_PUBLIC_NEO4J_PASSWORD=

NEXT_PUBLIC_BUTTERBASE_APP_ID=
NEXT_PUBLIC_BUTTERBASE_API_URL=https://api.butterbase.ai

# Demo auto-login — avoids Butterbase sign-up rate limits during demos.
# The password also ends up in the bundle; use only a throwaway demo account.
NEXT_PUBLIC_AUTO_LOGIN=1
NEXT_PUBLIC_DEMO_EMAIL=oncall@rescueops.dev
NEXT_PUBLIC_DEMO_PASSWORD=
