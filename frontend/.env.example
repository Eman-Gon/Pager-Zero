# Copy to .env.local (or let ./scripts/dev-native.sh generate it from root .env)

# Backend endpoints. Defaults are /sensor + /responder, which ONLY work through
# the Vite dev proxy (npm run dev). For any static/hosted deploy these MUST be
# absolute URLs or every panel silently shows "offline".
VITE_SENSOR_URL=http://127.0.0.1:3003
VITE_RESPONDER_URL=http://127.0.0.1:3004

# Neo4j browser-bolt for the graph panel. WARNING: Vite bakes these into the JS
# bundle — anyone loading a deployed build gets the DB password. Leave BLANK for
# hosted builds (the graph falls back to the /incident subgraph, server-side).
VITE_NEO4J_URL=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
VITE_NEO4J_USER=neo4j
VITE_NEO4J_PASSWORD=

VITE_BUTTERBASE_APP_ID=
VITE_BUTTERBASE_API_URL=https://api.butterbase.ai

# Demo auto-login — avoids Butterbase sign-up rate limits during hackathon demos.
# The password also ends up in the bundle; use only a throwaway demo account.
VITE_AUTO_LOGIN=1
VITE_DEMO_EMAIL=oncall@rescueops.dev
VITE_DEMO_PASSWORD=
