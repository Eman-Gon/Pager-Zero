# Mission Control — Next.js app with same-origin API rewrites.
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

ARG NEXT_PUBLIC_BUTTERBASE_APP_ID=app_gsuwgmmbc74g
ARG NEXT_PUBLIC_BUTTERBASE_API_URL=https://api.butterbase.ai
ARG NEXT_PUBLIC_NEO4J_URL=
ARG NEXT_PUBLIC_NEO4J_USER=
ARG NEXT_PUBLIC_NEO4J_PASSWORD=
ARG NEXT_PUBLIC_AUTO_LOGIN=1
ARG NEXT_PUBLIC_DEMO_EMAIL=oncall@rescueops.dev
ARG NEXT_PUBLIC_DEMO_PASSWORD=Resc!ue0ps2026
ARG SENSOR_REWRITE_URL=http://sensor:3003
ARG RESPONDER_REWRITE_URL=http://responder:3004

ENV NEXT_OUTPUT=standalone \
    NEXT_PUBLIC_BUTTERBASE_APP_ID=$NEXT_PUBLIC_BUTTERBASE_APP_ID \
    NEXT_PUBLIC_BUTTERBASE_API_URL=$NEXT_PUBLIC_BUTTERBASE_API_URL \
    NEXT_PUBLIC_NEO4J_URL=$NEXT_PUBLIC_NEO4J_URL \
    NEXT_PUBLIC_NEO4J_USER=$NEXT_PUBLIC_NEO4J_USER \
    NEXT_PUBLIC_NEO4J_PASSWORD=$NEXT_PUBLIC_NEO4J_PASSWORD \
    NEXT_PUBLIC_AUTO_LOGIN=$NEXT_PUBLIC_AUTO_LOGIN \
    NEXT_PUBLIC_DEMO_EMAIL=$NEXT_PUBLIC_DEMO_EMAIL \
    NEXT_PUBLIC_DEMO_PASSWORD=$NEXT_PUBLIC_DEMO_PASSWORD \
    SENSOR_REWRITE_URL=$SENSOR_REWRITE_URL \
    RESPONDER_REWRITE_URL=$RESPONDER_REWRITE_URL

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production \
    HOSTNAME=0.0.0.0 \
    PORT=3000
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
EXPOSE 3000
CMD ["node", "server.js"]
