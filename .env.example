# M3 external services — copy to .env and fill in. Never commit .env.

# LLM diagnosis — direct OpenAI-compatible chat/completions.
# Provider: butterbase (default) | openai | nebius
LLM_PROVIDER=butterbase
# Timeout (ms) for a single /diagnose LLM call. Default 120000.
# RESCUEOPS_DIAGNOSE_TIMEOUT_MS=120000

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Butterbase AI gateway (when LLM_PROVIDER=butterbase, default)
# Cognee memory service (Integrations 1 & 3). Runs as services/memory (compose
# profile "memory"). Writes its knowledge graph into the SAME Neo4j as the code
# graph (distinct labels). Both flags default off; responder falls back to its
# built-in runbook substrate when unset or the service is unreachable.
MEMORY_URL=http://localhost:3005
#   COGNEE_ENABLED=1          # Integration 1: Cognee knowledge-graph runbook recall
#   COGNEE_MEMORY_ENABLED=1   # Integration 3: persistent episodic incident memory
COGNEE_ENABLED=0
COGNEE_MEMORY_ENABLED=0
# Cognee LLM (entity extraction) + embeddings default to Butterbase gateway +
# Nebius; override with COGNEE_LLM_* / COGNEE_EMBEDDING_* only if needed.
# EMBEDDING_DIMENSIONS must match your Nebius embed model (else Cognee assumes 3072).
COGNEE_EMBEDDING_DIMENSIONS=

# Butterbase AI gateway, OpenAI-compatible "gateway mode" (no app_id needed).
# Key must be a personal API key with the `ai:gateway` scope — mint at
# dashboard /api-keys (POST /api-keys with scopes: ["ai:gateway"]).
BUTTERBASE_GATEWAY_URL=https://api.butterbase.ai/v1
BUTTERBASE_API_KEY=
BUTTERBASE_CHAT_MODEL=anthropic/claude-sonnet-4.6

# Demo mode: grant apply credits without Stripe (Mission Control local dev).
DEMO_AUTO_CREDITS=1

# Butterbase frontend deploy (./scripts/deploy-frontend.sh) — public URLs for the
# hosted Mission Control UI (cannot reach localhost). Use a VPS or tunnel.
#   VITE_SENSOR_URL=https://your-host:3003
#   VITE_RESPONDER_URL=https://your-host:3004
# Optional: lock CORS on sensor/responder to your Pages origin:
#   CORS_ORIGIN=https://your-app.pages.dev

# Unlimited mode: bypass the credit paywall entirely (applies/ships never blocked).
# MUST stay 0 for the real paywall + the e2e credit proofs (e2e.sh strict 5→4
# decrement, e2e-negative.sh 402) to pass. Set to 1 only for throwaway local dev.
UNLIMITED_CREDITS=0
MAX_CANDIDATES=25

# Nebius Token Factory (OpenAI-compatible; formerly AI Studio). Confirm the
# current embedding model ID at https://tokenfactory.nebius.com/models —
# model IDs change; the smoke script records the returned vector dimension.
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_API_KEY=
NEBIUS_EMBED_MODEL=

# Daytona (M4 sandbox verification — key from app.daytona.io dashboard).
# DAYTONA_API_URL only if your account uses a non-default endpoint.
DAYTONA_API_KEY=
DAYTONA_API_URL=

# Opsera (M6 Phase 2 — governance). Webhook-triggered pipeline that records the
# deployment + DORA Time-to-Restore. The policy-as-code gate (opsera-policy.json)
# is enforced locally BEFORE any credit/PR — a disallowed fix is blocked (HTTP 422),
# no PR opened. Leave OPSERA_WEBHOOK_URL unset to disable (baseline demo unchanged).
OPSERA_WEBHOOK_URL=
OPSERA_API_KEY=
OPSERA_PIPELINE_ID=rescueops-ship

# Autonomous mode: when AUTONOMOUS=1 the responder watches the sensor and, for
# each new incident, drives diagnose → remediate → apply with no human click.
# It signs in as the service (on-call) account below so everything persists
# under RLS; risky fixes still park as pending approvals (never auto-shipped).
# Needs Butterbase configured. Leave AUTONOMOUS unset for manual (dashboard) mode.
AUTONOMOUS=0
SERVICE_EMAIL=oncall@rescueops.dev
SERVICE_PASSWORD=            # demo on-call account password — never commit a real value
AUTONOMOUS_POLL_MS=5000

# External incident sources (opt-in, additive). Inbound webhooks drive the same
# headless chain as autonomous mode, so they need Butterbase + SERVICE_PASSWORD
# above. The responder must be publicly reachable for real webhooks (use ngrok /
# a tunnel); for a local demo, leave the *_WEBHOOK_SECRET blank and curl the route
# directly (signature verification is skipped when no secret is set).
#
# PagerDuty: a V3 webhook `incident.triggered` triggers diagnosis; the page is
# auto-resolved on ship (REST API) with a note linking the PR + MTTR.
PAGERDUTY_ENABLED=0
PAGERDUTY_WEBHOOK_SECRET=       # V3 webhook signing secret (verify X-PagerDuty-Signature)
PAGERDUTY_API_TOKEN=           # REST API token used to resolve the incident on ship
PAGERDUTY_FROM_EMAIL=          # a valid PD user email (required by the REST API 'From' header)
#
# Sentry: an error webhook triggers diagnosis and its stack trace seeds/confirms
# the root-cause function; the issue is resolved on ship.
SENTRY_ENABLED=0
SENTRY_WEBHOOK_SECRET=         # integration client secret (verify Sentry-Hook-Signature)
SENTRY_AUTH_TOKEN=             # auth token with event:write / project:write to resolve issues

# Neo4j (Aura or local) — REQUIRED: dev-native.sh exits without NEO4J_URI/URL,
# and preflight.sh checks all of these. Aura: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# GitHub shipping (M6) — classic PAT with Contents + Pull-requests write on GITHUB_REPO.
GITHUB_TOKEN=
GITHUB_REPO=

# Butterbase app (M5 persistence + auth) — app id from dashboard.butterbase.ai.
BUTTERBASE_APP_ID=
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_PLAN_CREDITS=5

# Optional overrides (defaults shown are what the code assumes):
#   SENSOR_URL=http://127.0.0.1:3003
#   RESPONDER_URL=http://127.0.0.1:3004
#   PATIENT_REPO=/abs/path/to/patient   # dev-native.sh target; defaults to ./target-repo
#   TARGET_DIR=                          # set by dev-native.sh/compose from PATIENT_REPO
