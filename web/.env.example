# Backend endpoints. Defaults proxy to the local sensor/responder via Next
# rewrites (see next.config.mjs). For a hosted deploy, set absolute public URLs.
NEXT_PUBLIC_SENSOR_URL=http://127.0.0.1:3003
NEXT_PUBLIC_RESPONDER_URL=http://127.0.0.1:3004

# The demo ships with self-contained mock data and runs with zero backend.
# Flip to 1 to fetch live incidents from the sensor instead.
NEXT_PUBLIC_USE_LIVE_DATA=0
